# ===================================
# AI Medical De-Identifier - Environment Variables
# ===================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ===================================
# Application Settings
# ===================================
APP_ENV=development
DEBUG=True

# ===================================
# Backend (FastAPI) Configuration
# ===================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===================================
# Frontend Configuration
# ===================================
FRONTEND_PORT=5500

# ===================================
# CORS Settings
# ===================================
# Comma-separated list of allowed origins (use * for all in development)
CORS_ALLOWED_ORIGINS=*

# ===================================
# File Upload Settings
# ===================================
UPLOAD_DIR=temp
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.txt

# ===================================
# OCR Configuration (Tesseract)
# ===================================
# Path to Tesseract executable (uncomment and set if not in PATH)
# TESSERACT_CMD=/usr/bin/tesseract
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# ===================================
# NLP / Presidio Configuration
# ===================================
SPACY_MODEL=en_core_web_sm
PRESIDIO_LANGUAGE=en

# ===================================
# Docker Settings
# ===================================
COMPOSE_PROJECT_NAME=ai-medical-deidentifier